# Portfolio Tracker - Environment Variables
# Copy this file to .env and fill in your values. Never commit .env

# Database (required for production; falls back to in-memory for local if unset in some paths)
# Use Vercel Postgres, Supabase, Neon, or local PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/portfolio_db
# or POSTGRES_URL=...

# Authentication (simple shared password for this personal app)
# If unset, the app runs without login (open access - useful for local dev only)
APP_PASSWORD=your-strong-password-here

# Secret for signing auth tokens (HMAC). Use a long random string in production.
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Optional: protect the daily snapshot cron endpoint
# When set, the /api/cron/snapshot endpoint requires: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=another-long-random-value-for-cron

# Google AdSense integration (all 4 required to enable live earnings fetch)
# Obtain via Google Cloud Console + AdSense API + OAuth refresh token
GOOGLE_ADSENSE_CLIENT_ID=
GOOGLE_ADSENSE_CLIENT_SECRET=
GOOGLE_ADSENSE_REFRESH_TOKEN=
GOOGLE_ADSENSE_ACCOUNT_ID=accounts/xxxxxxxx

# Optional
NODE_ENV=development
PORT=5001
