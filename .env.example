# Portfolio Tracker - Environment Variables
# Copy this file to .env and fill in your values. Never commit .env

# Database (required for production; falls back to in-memory for local if unset in some paths)
# Use Vercel Postgres, Supabase, Neon, or local PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/portfolio_db
# or POSTGRES_URL=...

# Authentication (simple shared password for this personal app)
# If unset, the app runs without login (open access - useful for local dev only)
APP_PASSWORD=your-strong-password-here

# Secret for signing auth tokens (HMAC). Use a long random string in production.
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Optional: protect the daily snapshot cron endpoint
# When set, the /api/cron/snapshot endpoint requires: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=another-long-random-value-for-cron

# Google Revenue (AdSense + optional YouTube)
# The /adsense page (now "Google Revenue") can show both.
# AdSense and YouTube can be under completely separate Google accounts, so they have separate OAuth credentials.
# 
# For AdSense (use AdSense Management API):
#   https://www.googleapis.com/auth/adsense.readonly
#
# For YouTube (use YouTube Analytics API):
#   https://www.googleapis.com/auth/yt-analytics-monetary.readonly
#   (For AUTO discovery of multiple channels:) https://www.googleapis.com/auth/youtube.readonly
#
# Note: Each refresh token is bound to the Google account you use during authorization.
# If revenue is under different accounts, authorize separately for each.
GOOGLE_ADSENSE_CLIENT_ID=
GOOGLE_ADSENSE_CLIENT_SECRET=
GOOGLE_ADSENSE_REFRESH_TOKEN=   # <-- You only need this long-lived token (not the short-lived access_token)
GOOGLE_ADSENSE_ACCOUNT_ID=accounts/pub-1234567890123456   # or just the pub- id

GOOGLE_YOUTUBE_CLIENT_ID=
GOOGLE_YOUTUBE_CLIENT_SECRET=
GOOGLE_YOUTUBE_REFRESH_TOKEN=
GOOGLE_YOUTUBE_CHANNEL_ID=AUTO   # Recommended. AUTO discovers your channels + content owners. Or hardcode the exact UC... ID (or contentOwner ID).

# Optional
NODE_ENV=development
PORT=5001
